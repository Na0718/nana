{
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(login\\.html|index\\.html)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "redirects": [
    { "source": "/login", "destination": "/login.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/public/$1" }
  ]
}